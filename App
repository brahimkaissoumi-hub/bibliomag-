              <div style={{ fontWeight: 700, fontSize: 13, color: "#374151", marginBottom: 10, textAlign: isRTL ? "right" : "left" }}>{t.readingSpeed}</div>
              <div style={{ display: "flex", gap: 7, flexDirection: isRTL ? "row-reverse" : "row" }}>
                {["0.75x", "1x", "1.25x", "1.5x"].map((v, i) => (
                  <button key={i} className="btn" style={{
                    flex: 1, padding: "8px 4px", borderRadius: 12, fontWeight: 700, fontSize: 12,
                    background: i === 1 ? "#7C3AED" : "#F3F4F6",
                    color: i === 1 ? "white" : "#374151", border: "none"
                  }}>{v}</button>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* ═══ PROFIL ═══ */}
        {page === "profil" && (
          <div className="slide-in" style={{ padding: "18px 15px" }}>
            <div style={{
              background: "linear-gradient(135deg, #EC4899, #8B5CF6)",
              borderRadius: 26, padding: 22, textAlign: "center", marginBottom: 18,
              boxShadow: "0 8px 24px rgba(236,72,153,0.3)"
            }}>
              <div style={{ fontSize: 58, marginBottom: 6 }}>🧒</div>
              <div style={{ fontFamily: isRTL ? "'Cairo'" : "'Baloo 2', cursive", fontSize: 22, fontWeight: 800, color: "white" }}>Sara</div>
              <div style={{ color: "rgba(255,255,255,0.8)", fontWeight: 600, marginBottom: 14, fontSize: 13 }}>
                {eleves[0].classe[lang]}
              </div>
              <div style={{ display: "flex", gap: 10, justifyContent: "center", flexDirection: isRTL ? "row-reverse" : "row" }}>
                {[
                  { val: "8", label: t.booksRead },
                  { val: "3", label: t.badges },
                  { val: "🥈", label: t.rank },
                ].map((s, i) => (
                  <div key={i} style={{ background: "rgba(255,255,255,0.18)", borderRadius: 14, padding: "8px 14px" }}>
                    <div style={{ fontWeight: 900, fontSize: 20, color: "white" }}>{s.val}</div>
                    <div style={{ fontSize: 10, color: "rgba(255,255,255,0.8)", fontWeight: 700 }}>{s.label}</div>
                  </div>
                ))}
              </div>
     {/* Badges */}
            <div style={{ marginBottom: 18 }}>
              <div style={{ fontWeight: 800, fontSize: 16, color: "#1E1B4B", marginBottom: 12, textAlign: isRTL ? "right" : "left" }}>{t.myBadgesTitle}</div>
              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 10 }}>
                {badges.map(b => (
                  <div key={b.id} className="card-hover" style={{
                    background: b.earned ? b.color + "22" : "#F9FAFB",
                    border: `2px solid ${b.earned ? b.color : "#E5E7EB"}`,
                    borderRadius: 18, padding: "14px 8px", textAlign: "center",
                    opacity: b.earned ? 1 : 0.55, position: "relative"
                  }}>
                    {b.earned && <div className="pop" style={{ position: "absolute", top: -6, right: isRTL ? "auto" : -6, left: isRTL ? -6 : "auto", background: "#10B981", color: "white", borderRadius: "50%", width: 17, height: 17, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 9, fontWeight: 800 }}>✓</div>}
                    <div style={{ fontSize: 30 }}>{b.earned ? b.icon : "🔒"}</div>
                    <div style={{ fontSize: 10, fontWeight: 700, color: b.earned ? "#1E1B4B" : "#9CA3AF", marginTop: 5, lineHeight: 1.3 }}>{b.label[lang]}</div>
                  </div>
                ))}
              </div>
            </div>

            {/* Classement */}
            <div style={{ fontWeight: 800, fontSize: 16, color: "#1E1B4B", marginBottom: 12, textAlign: isRTL ? "right" : "left" }}>{t.classRanking}</div>
            <div style={{ display: "flex", flexDirection: "column", gap: 9 }}>
              {[...eleves].sort((a, b) => b.livresLus - a.livresLus).map((e, i) => (
                <div key={e.id} style={{
                  background: e.nom === "Sara" ? "linear-gradient(135deg,#EDE9FE,#DDD6FE)" : "white",
                  borderRadius: 14, padding: "11px 14px",
                  border: e.nom === "Sara" ? "2px solid #A78BFA" : "2px solid #F3F4F6",
                  display: "flex", alignItems: "center", gap: 10,
                  boxShadow: "0 3px 10px rgba(0,0,0,0.05)",
                  flexDirection: isRTL ? "row-reverse" : "row"
                }}>
                  <div style={{ width: 30, height: 30, borderRadius: "50%", background: i === 0 ? "#FFD700" : i === 1 ? "#C0C0C0" : "#CD7F32", display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900, fontSize: 13, color: "white", flexShrink: 0 }}>
                    {i + 1}
                  </div>
                  <span style={{ fontSize: 26 }}>{e.avatar}</span>
                  <div style={{ flex: 1, textAlign: isRTL ? "right" : "left" }}>
                    <div style={{ fontWeight: 800, fontSize: 13, color: "#1E1B4B" }}>{e.nom} {e.nom === "Sara" && (isRTL ? "👈" : "👈")}</div>
                    <div style={{ fontSize: 10, color: "#6B7280", fontWeight: 600 }}>{e.classe[lang]} • {t.inProgress}: {e.enCours[lang]}</div>
                  </div>
                  <div style={{ textAlign: isRTL ? "left" : "right" }}>
                    <div style={{ fontWeight: 900, fontSize: 17, color: "#7C3AED" }}>{e.livresLus}</div>
                    <div style={{ fontSize: 10, color: "#9CA3AF", fontWeight: 600 }}>{t.books}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ═══ ADMIN ═══ */}
        {page === "admin" && (
          <div className="slide-in" style={{ padding: "18px 15px" }}>
            <div style={{ fontFamily: isRTL ? "'Cairo'" : "'Baloo 2', cursive", fontWeight: 800, fontSize: 22, color: "#1E1B4B", marginBottom: 3, textAlign: isRTL ? "right" : "left" }}>
              {t.adminTitle}
            </div>
            <div style={{ color: "#6B7280", fontSize: 12, fontWeight: 600, marginBottom: 18, textAlign: isRTL ? "right" : "left" }}>{t.adminSub}</div>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 18 }}>
              {[
                { icon: "📚", val: livres.length, label: t.totalBooks, bg: "#EDE9FE", c: "#7C3AED" },
                { icon: "👧", val: eleves.length, label: t.students, bg: "#DCFCE7", c: "#059669" },
                { icon: "📤", val: emprunts.length, label: t.activeLoans, bg: "#FEF3C7", c: "#D97706" },
                { icon: "⏰", val: "1", label: t.late, bg: "#FEE2E2", c: "#DC2626" },
              ].map((s, i) => (
                <div key={i} style={{ background: s.bg, borderRadius: 16, padding: 14, boxShadow: "0 4px 12px rgba(0,0,0,0.07)", textAlign: isRTL ? "right" : "left" }}>
                  <div style={{ fontSize: 26, marginBottom: 3 }}>{s.icon}</div>
                  <div style={{ fontSize: 24, fontWeight: 900, color: s.c, fontFamily: isRTL ? "'Cairo'" : "'Baloo 2', cursive" }}>{s.val}</div>
                  <div style={{ fontSize: 11, color: s.c, fontWeight: 700 }}>{s.label}</div>
                </div>
              ))}
            </div>

            <div style={{ fontWeight: 800, fontSize: 16, color: "#1E1B4B", marginBottom: 10, textAlign: isRTL ? "right" : "left" }}>{t.currentLoans}</div>
            <div style={{ display: "flex", flexDirection: "column", gap: 9, marginBottom: 18 }}>
              {emprunts.map((em, i) => (
                <div key={i} style={{
                  background: "white", borderRadius: 14, padding: "12px 14px",
                  display: "flex", alignItems: "center", gap: 10,
                  boxShadow: "0 3px 10px rgba(0,0,0,0.06)",
                  flexDirection: isRTL ? "row-reverse" : "row"
                }}>
                  <span style={{ fontSize: 26 }}>📗</span>
                  <div style={{ flex: 1, textAlign: isRTL ? "right" : "left" }}>
                    <div style={{ fontWeight: 800, fontSize: 13, color: "#1E1B4B" }}>{em.livre[lang]}</div>
                    <div style={{ fontSize: 11, color: "#6B7280", fontWeight: 600 }}>{t.by} {em.eleve} • {t.since} {em.date}</div>
                  </div>
                  <div style={{ background: "#FEF3C7", color: "#D97706", borderRadius: 10, padding: "3px 9px", fontSize: 10, fontWeight: 800 }}>
                    {t.return} {em.retour}
                  </div>
                </div>
              ))}
            </div>

            <div style={{ fontWeight: 800, fontSize: 16, color: "#1E1B4B", marginBottom: 10, textAlign: isRTL ? "right" : "left" }}>{t.quickActions}</div>
            <div style={{ display: "flex", flexDirection: "column", gap: 9 }}>
              {[
                { icon: "➕", label: t.addBook, color: "#7C3AED" },
                { icon: "👤", label: t.addStudent, color: "#059669" },
                { icon: "📊", label: t.viewStats, color: "#D97706" },
                { icon: "📥", label: t.importEbooks, color: "#2563EB" },
              ].map((a, i) => (
                <button key={i} className="btn" onClick={() => showNotif(`${a.label} — ${t.comingSoon}`, "🔧")} style={{
                  background: "white", border: `2px solid ${a.color}22`,
                  borderRadius: 13, padding: "13px 14px", display: "flex",
                  alignItems: "center", gap: 10, fontWeight: 700, fontSize: 13, color: a.color,
                  boxShadow: "0 3px 10px rgba(0,0,0,0.05)",
                  textAlign: isRTL ? "right" : "left",
                  flexDirection: isRTL ? "row-reverse" : "row",
                  fontFamily
                }}>
                  <span style={{ fontSize: 20 }}>{a.icon}</span>
                  {a.label}
                  <span style={{ marginLeft: isRTL ? 0 : "auto", marginRight: isRTL ? "auto" : 0, fontSize: 15 }}>
                    {isRTL ? "←" : "→"}
                  </span>
                </button>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* BARRE NAV */}
      <div style={{
        position: "fixed", bottom: 0, left: 0, right: 0,
        background: "white", borderTop: "1px solid #F3F4F6",
        padding: "7px 0 11px",
        display: "flex", justifyContent: "space-around",
        boxShadow: "0 -4px 20px rgba(0,0,0,0.07)",
        zIndex: 100, maxWidth: 480, margin: "0 auto",
        flexDirection: isRTL ? "row-reverse" : "row"
      }}>
        {[
          { icon: "🏠", label: t.nav.home, p: "accueil" },
          { icon: "📚", label: t.nav.catalogue, p: "catalogue" },
          { icon: "🎧", label: t.nav.listen, p: "lecture" },
          { icon: "👤", label: t.nav.profile, p: "profil" },
          { icon: "⚙️", label: t.nav.admin, p: "admin" },
        ].map(nav => (
          <button key={nav.p} className="nav-btn" onClick={() => setPage(nav.p)} style={{
            display: "flex", flexDirection: "column", alignItems: "center", gap: 2,
            padding: "3px 10px", borderRadius: 12,
            background: page === nav.p ? "#EDE9FE" : "transparent"
          }}>
            <span style={{ fontSize: 20 }}>{nav.icon}</span>
            <span style={{ fontSize: 9, fontWeight: 700, color: page === nav.p ? "#7C3AED" : "#9CA3AF", fontFamily }}>
              {nav.label}
            </span>
          </button>
        ))}
      </div>
    </div>
  ); 
}
  

  
